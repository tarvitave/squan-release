# Squan v2.0.0 Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# PHASE 1: MULTI-MODEL SUPPORT
# =============================================================================

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI GPT API
OPENAI_API_KEY=sk-your-key-here
OPENAI_API_ENDPOINT=  # Optional: Custom endpoint for Azure OpenAI

# Google Gemini API
GOOGLE_API_KEY=your-key-here

# Azure OpenAI (Optional)
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=

# Ollama (Local LLM - Optional)
OLLAMA_ENDPOINT=http://localhost:11434

# Default Provider Settings
DEFAULT_PROVIDER=anthropic  # anthropic | openai | google | azure | ollama
DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Provider Fallback Chain (Optional - JSON format)
# Automatically try next provider if one fails
PROVIDER_FALLBACK_CONFIG={"providers":[{"type":"anthropic","model":"claude-3-5-sonnet-20241022"},{"type":"openai","model":"gpt-4o"},{"type":"google","model":"gemini-2.0-flash-exp"}],"strategy":"sequential"}

# =============================================================================
# CONTEXT MANAGEMENT
# =============================================================================

# Token usage thresholds (0.0 - 1.0)
CONTEXT_WARNING_THRESHOLD=0.7   # Warn at 70% utilization
CONTEXT_COMPACTION_THRESHOLD=0.8  # Auto-compact at 80% utilization

# Compaction strategy
CONTEXT_COMPACTION_STRATEGY=summarization  # sliding_window | summarization | importance_sampling

# Summarizer model (use cheaper model for cost savings)
CONTEXT_SUMMARIZER_MODEL=gpt-3.5-turbo

# =============================================================================
# PHASE 2: RECIPES & WORKFLOWS
# =============================================================================

# Recipe directories (comma-separated)
RECIPES_DIR=/app/recipes,/app/recipes/community

# Recipe registry URL (Optional - for recipe marketplace)
RECIPE_REGISTRY_URL=

# Subagent limits
MAX_CONCURRENT_SUBAGENTS=5
SUBAGENT_DEFAULT_TIMEOUT=1800  # 30 minutes in seconds
SUBAGENT_ISOLATION_LEVEL=strict  # strict | moderate | none

# =============================================================================
# MCP EXTENSIONS
# =============================================================================

# GitHub Extension
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your-token-here

# PostgreSQL Extension
DATABASE_URL=postgresql://user:password@localhost:5432/database

# Slack Extension (Optional)
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# Linear Extension (Optional)
LINEAR_API_KEY=

# =============================================================================
# CLI CONFIGURATION
# =============================================================================

# Squan API URL (for CLI)
SQUAN_API_URL=http://localhost:3001

# CLI API Key (Optional - for authentication)
SQUAN_API_KEY=

# CLI default output format
CLI_DEFAULT_FORMAT=table  # table | json | yaml

# =============================================================================
# COST MANAGEMENT
# =============================================================================

# Budget alerts (dollar amounts)
COST_ALERT_THRESHOLD_1=50.00
COST_ALERT_THRESHOLD_2=100.00
COST_ALERT_THRESHOLD_3=500.00

# Budget alert actions
COST_ALERT_ACTION=notify  # notify | pause_new_agents | stop_all_agents

# Alert recipients (comma-separated emails)
COST_ALERT_RECIPIENTS=admin@example.com

# =============================================================================
# DATABASE
# =============================================================================

# SQLite (Default)
DATABASE_PATH=/data/squan.db

# PostgreSQL (Optional - comment out DATABASE_PATH if using PostgreSQL)
# POSTGRES_DB=squan
# POSTGRES_USER=squan
# POSTGRES_PASSWORD=secure-password-here
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Node environment
NODE_ENV=production  # development | production

# Server port
PORT=3001

# Log level
LOG_LEVEL=info  # debug | info | warn | error

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your-secret-key-here

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# WORKERBEE SETTINGS
# =============================================================================

# Docker image for WorkerBees
WORKERBEE_IMAGE=ghcr.io/tarvitave/squan-workerbee:v2.0.0

# WorkerBee resource limits
WORKERBEE_MEMORY_LIMIT=2g
WORKERBEE_CPU_LIMIT=2.0

# Git worktree settings
WORKTREE_BASE_PATH=/repos/worktrees
WORKTREE_CLEANUP_AFTER_HOURS=24

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Enable metrics collection
ENABLE_METRICS=true

# Prometheus metrics endpoint
METRICS_PORT=9090

# Sentry error tracking (Optional)
SENTRY_DSN=

# =============================================================================
# DEVELOPMENT SETTINGS (Only for development)
# =============================================================================

# Enable debug mode
DEBUG=false

# Mock external services
MOCK_PROVIDERS=false
MOCK_EXTENSIONS=false

# Disable authentication
DISABLE_AUTH=false
